{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Control-BVVM",
  "version": "0.2.8",
  "identifier": "com.controlbvvm.control",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Control BVVM",
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi"],
    "icon": [
      "icons/bvvm64x64.ico",
      "icons/bvvm128x128.ico",
      "icons/bvvm256x256.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://fabriB99.github.io/app-escritorio-bvvm/latest.json"
      ],
      "dialog": false,
      "pubkey": "RWSicYZjytOcH9yJlLqegYpTPPmalD/6I/wXRcNI52MxQajS4rQwl15Z"
    }
  }
}